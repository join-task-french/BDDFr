{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Mods d'armes — The Division 2",
  "description": "Clé = slug du mod.",
  "type": "object",
  "additionalProperties": false,
  "patternProperties": {
    "^[a-z0-9_]+$": {
      "type": "object",
      "required": [
        "nom"
      ],
      "properties": {
        "nom": {
          "type": "string",
          "description": "Nom de la modification"
        },
        "type": {
          "type": "string",
          "enum": [
            "chargeur",
            "canon",
            "viseur",
            "accessoire",
            "autre"
          ],
          "description": "Type de modification"
        },
        "bonus": {
          "type": "string",
          "description": "Bonus apporté"
        },
        "malus": {
          "type": "string",
          "description": "Malus apporté"
        },
        "estExotique": {
          "type": "boolean",
          "description": "True si mod exotique (lié à une arme exotique, non modifiable)"
        }
      }
    }
  }
}
