{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Mods d'armes — The Division 2",
  "description": "Clé = slug du mod.",
  "type": "object",
  "additionalProperties": false,
  "patternProperties": {
    "^[a-z0-9_]+$": {
      "type": "object",
      "required": [
        "nom",
        "compatible",
        "type",
        "bonus"
      ],
      "properties": {
        "nom": {
          "type": "string",
          "description": "Nom de la modification"
        },
        "compatible": {
          "type": "array",
          "description": "Types d'armes compatibles avec ce mod",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9_]+$",
            "description": "Slug type d'arme compatible",
            "minItems": 1
          }
        },
        "type": {
          "type": "string",
          "enum": [
            "chargeur",
            "canon",
            "viseur",
            "accessoire",
            "autre"
          ],
          "description": "Type de modification"
        },
        "bonus": {
          "type": "string",
          "description": "Bonus apporté"
        },
        "malus": {
          "type": "string",
          "description": "Malus apporté"
        },
        "estExotique": {
          "type": "boolean",
          "description": "True si mod exotique (lié à une arme exotique, non modifiable)"
        }
      }
    }
  }
}
