{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Types Armes — The Division 2",
  "description": "Type d'armes + attributs essentiels lié",
  "type": "object",
  "additionalProperties": false,
  "patternProperties": {
    "^[a-z0-9_]+$": {
      "type": "object",
      "properties": {
        "nom": {
          "type": "string"
        },
        "attributs_essentiels": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9_]+$"
          },
          "minItems": 1
        },
        "icon": {
          "type": "string"
        }
      },
      "required": [
        "attributs_essentiels",
        "icon",
        "nom"
      ],
      "additionalProperties": false
    }
  }
}
