{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Équipements — The Division 2",
  "description": "Toutes les pièces d'équipement. Clé = slug de l'équipement.",
  "type": "object",
  "additionalProperties": false,
  "patternProperties": {
    "^[a-z0-9_]+$": {
      "type": "object",
      "required": [
        "nom",
        "emplacement"
      ],
      "properties": {
        "nom": {
          "type": "string"
        },
        "marque": {
          "type": "string",
          "description": "Slug de la marque/gear set, ou 'Exotique'"
        },
        "emplacement": {
          "type": "string",
          "enum": [
            "masque",
            "torse",
            "holster",
            "sac_a_dos",
            "gants",
            "genouilleres"
          ]
        },
        "attributEssentiel": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "offensif",
              "défensif",
              "utilitaire"
            ]
          }
        },
        "attributUnique": {
          "type": "string"
        },
        "attributs": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "nom",
              "valeur"
            ],
            "properties": {
              "nom": {
                "type": "string"
              },
              "valeur": {
                "type": "number"
              }
            }
          }
        },
        "talent": {
          "type": "string"
        },
        "talents": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "mod": {
          "type": "boolean"
        },
        "estNomme": {
          "type": "boolean"
        },
        "type": {
          "type": "string",
          "enum": [
            "standard",
            "gear_set",
            "exotique"
          ]
        },
        "obtention": {
          "type": "string"
        }
      }
    }
  }
}
